           className=\u0027p-1.5 text-slate-400 hover:text-slate-600 min-[860px]:hidden\u0027\\n                  \u003e\\n                    \u003cX size={16} /\u003e\\n                  \u003c/button\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv className=\u0027flex-1 overflow-y-auto\u0027\u003e\\n                  {activeRightTab === \u0027ticket\u0027 ? (\\n                    \u003cdiv className=\u0027p-4 space-y-5\u0027\u003e\\n                      \u003cdiv\u003e\\n                        \u003cspan className=\u0027text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1\u0027\u003e\\n                          ID do Ticket\\n                        \u003c/span\u003e\\n                        \u003cp className=\u0027text-sm font-bold text-slate-900 dark:text-white\u0027\u003e\\n                          #{selectedTicket.id.slice(0, 8)}\\n                        \u003c/p\u003e\\n                        \u003cspan className=\u0027text-[11px] text-slate-500\u0027\u003e\\n                          {selectedTicket.category}\\n                        \u003c/span\u003e\\n                      \u003c/div\u003e\\n\\n                      \u003cdiv className=\u0027space-y-3\u0027\u003e\\n                        \u003ch4 className=\u0027text-[9px] font-black text-slate-400 uppercase tracking-widest\u0027\u003e\\n                          Respons├ível\\n                        \u003c/h4\u003e\\n                        \u003cdiv className=\u0027relative\u0027\u003e\\n                          \u003cselect\\n                            value={selectedTicket.assigned_to || \u0027\u0027}\\n                            onChange={(e) =\u003e\\n                              handleAssign(selectedTicket.id, e.target.value || null)\\n                            }\\n                            className=\u0027w-full pl-3 pr-8 py-2 bg-slate-50 dark:bg-slate-800 border border-gray-100 dark:border-white/10 rounded-xl text-[11px] font-bold text-